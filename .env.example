# Used both for running the app directly with `python app.py` and by
# docker-compose.yml (which reads this file automatically).
#
# Local run:  DB_HOST should point at your MySQL server (often "localhost").
# docker-compose run: DB_HOST is hardcoded to "db" in docker-compose.yml,
# so the value below is only used for local (non-Docker) runs. DB_PASSWORD
# is shared with docker-compose's MySQL container password either way.

FLASK_SECRET_KEY=change-this-to-something-random
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=village_journey
